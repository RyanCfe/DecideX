<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvOptionName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rate option 1 of 3"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvCurrentOption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Study"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#6200EE"
        android:padding="16dp"
        android:background="#F3E5F5"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <!-- Importance -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How IMPORTANT is this option?"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Does this actually matter to your life right now?"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <SeekBar
            android:id="@+id/sbImportance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="10"
            android:progress="5"/>

        <TextView
            android:id="@+id/tvImportanceVal"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="5/10"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="#6200EE"/>
    </LinearLayout>

    <!-- Desire -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How much do you WANT to do this?"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Be honest — do you actually feel like doing it?"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <SeekBar
            android:id="@+id/sbDesire"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="10"
            android:progress="5"/>

        <TextView
            android:id="@+id/tvDesireVal"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="5/10"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="#6200EE"/>
    </LinearLayout>

    <!-- Effort -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How much EFFORT does this require?"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="High effort = tiring. Low effort = easy."
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="40dp">

        <SeekBar
            android:id="@+id/sbEffort"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="10"
            android:progress="5"/>

        <TextView
            android:id="@+id/tvEffortVal"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="5/10"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="#6200EE"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnNextOption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Next Option →"/>

</LinearLayout>
