<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Import Notes from File"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pick a .txt file to read your notes or decision context"
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnPickFile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose Text File"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvFileName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No file selected"
        android:textStyle="italic"
        android:textColor="#888888"
        android:layout_marginBottom="12dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvFileContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="File contents will appear here..."
            android:textSize="14sp"
            android:padding="12dp"
            android:background="#F5F5F5"
            android:scrollbars="vertical"/>

    </ScrollView>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Back to Home"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>

</LinearLayout>
